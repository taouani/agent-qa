version: 1.0.0
last_installed: 2025-01-01 00:00:00


# CONFIGURATION
# Configure repository platform and project settings for Agent QA.


# ================================================
# Repository Platform
# Select which git repository platform Agent QA should use:
# - gitlab: Use GitLab MCP server
# - github: Use GitHub MCP server
# - azure-devops: Use Azure DevOps MCP server
#
# This setting determines which MCP server tools Agent QA will use for
# commit analysis, pull request/merge request retrieval, and code change tracking.
# ================================================
repository_platform: gitlab


# ================================================
# Repository Project ID
# The project ID or identifier for your git repository.
#
# Format depends on selected platform:
# - GitLab: Numeric project ID or full path (e.g., "12345" or "my-group/my-project")
# - GitHub: Repository owner/name (e.g., "octocat/Spoon-Knife")
# - Azure DevOps: Project name/ID and repository ID/name
#
# This is required for all repository operations.
# ================================================
repository_project_id: ""


# ================================================
# Azure DevOps Cloud ID
# Azure DevOps organization/account name (required only if repository_platform is azure-devops).
#
# Example: "myorganization" for https://dev.azure.com/myorganization
#
# Leave empty if not using Azure DevOps.
# ================================================
azure_devops_cloud_id: ""


# ================================================
# Output Formats
# Enable additional output formats for generated deliverables.
#
# - confluence: Generate Confluence storage format (.confluence.html) files
# - gherkin: Generate Gherkin .feature files from test cases
#
# These are disabled by default. Enable them to generate additional formats
# alongside the standard markdown output.
# ================================================
output_formats:
  confluence: false
  gherkin: false


# ================================================
# Confluence Publishing
# Configuration for publishing deliverables to Confluence.
#
# Required only if you want to publish deliverables directly to Confluence
# via the Atlassian MCP server. Leave empty to generate .confluence.html
# files without publishing.
#
# - confluence_space_key: The Confluence space key (e.g., "QA", "TESTING")
# - confluence_parent_page_id: The parent page ID under which to create pages
# ================================================
confluence_space_key: ""
confluence_parent_page_id: ""


# ================================================
# Playwright Configuration
# Configuration for Playwright test generation.
#
# - playwright_base_url: The base URL for the application under test
#   Used in Page Object goto() methods and test navigation.
#   Example: "http://localhost:3000" or "https://staging.example.com"
# ================================================
playwright_base_url: "http://localhost:3000"

