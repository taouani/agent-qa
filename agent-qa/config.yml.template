version: 1.0.0
last_installed: 2025-01-01 00:00:00


# ================================================
# Installed IDEs
# Comma-separated list of IDEs configured during installation.
# Managed by project-install.sh — do not edit manually.
# Valid values: claude, cursor, vscode, github
# ================================================
installed_ides: ""


# CONFIGURATION
# Configure repository platform and project settings for Agent QA.


# ================================================
# Repository Platform
# Select which git repository platform Agent QA should use:
# - gitlab: Use GitLab MCP server
# - github: Use GitHub MCP server
# - azure-devops: Use Azure DevOps MCP server
#
# This setting determines which MCP server tools Agent QA will use for
# commit analysis, pull request/merge request retrieval, and code change tracking.
# ================================================
repository_platform: gitlab


# ================================================
# Repository Project ID
# The project ID or identifier for your git repository.
#
# Format depends on selected platform:
# - GitLab: Numeric project ID or full path (e.g., "12345" or "my-group/my-project")
# - GitHub: Repository owner/name (e.g., "octocat/Spoon-Knife")
# - Azure DevOps: Project name/ID and repository ID/name
#
# This is required for all repository operations.
# ================================================
repository_project_id: ""


# ================================================
# Azure DevOps Cloud ID
# Azure DevOps organization/account name (required only if repository_platform is azure-devops).
#
# Example: "myorganization" for https://dev.azure.com/myorganization
#
# Leave empty if not using Azure DevOps.
# ================================================
azure_devops_cloud_id: ""


# ================================================
# Default Language Override
# Override automatic language detection for all deliverables.
# Leave empty to use automatic detection (recommended).
# Example values: "en", "fr", "ar", "es", "de", "pt", "nl", "it"
# ================================================
default_language: ""


# ================================================
# Test Types
# Filter which test types to include in generated test cases.
# Remove entries to exclude specific test types from generation.
# ================================================
test_types:
  - functional
  - security
  - performance
  - accessibility


# ================================================
# Custom Labels
# Additional labels to add to all generated test cases.
# These are appended to auto-generated labels in CSV/Xray exports.
# Example: ["regression", "sprint-42", "team-alpha"]
# ================================================
custom_labels: []


# ================================================
# Output Formats
# Enable additional output formats for generated deliverables.
# These are disabled by default. Enable them to generate additional formats
# alongside the standard markdown output.
# ================================================
output_formats:
  confluence: false              # Generate Confluence storage format (.confluence.html) files
  gherkin: false                 # Generate Gherkin .feature files from test cases
  playwright: false              # Generate Playwright .spec.ts and .page.ts files
  xray_json: false               # Generate Xray JSON import file alongside CSV
  api_tests: false               # Generate API test specifications
  accessibility_tests: false     # Generate WCAG 2.1 AA accessibility tests
  testrail: false                # Generate TestRail CSV import file


# ================================================
# Confluence Publishing
# Configuration for publishing deliverables to Confluence.
#
# Required only if you want to publish deliverables directly to Confluence
# via the Atlassian MCP server. Leave empty to generate .confluence.html
# files without publishing.
# ================================================
confluence_space_key: ""
confluence_parent_page_id: ""


# ================================================
# Playwright Configuration
# Configuration for Playwright test generation.
# ================================================
# ================================================
# API Test Configuration
# Configuration for API test generation.
# ================================================
api_test_base_url: ""                    # Base URL for API tests (e.g., "https://api.example.com/v1")

playwright_base_url: "http://localhost:3000"
playwright_browser: "chromium"               # chromium | firefox | webkit
playwright_viewport: "1280x720"


# ================================================
# Post-Generation Hooks
# Custom shell commands to run after deliverable generation.
# Each hook runs in the project root directory.
# Available variables: {output_folder}, {command_name}, {context}
# ================================================
hooks:
  post_generate: []
  # Example hooks:
  # post_generate:
  #   - "echo 'Generated {command_name} in {output_folder}'"
  #   - "git add {output_folder}"
  #   - "npm run lint -- {output_folder}/**/*.ts"
  #   - "cp {output_folder}/test-cases/*.csv /shared/imports/"

